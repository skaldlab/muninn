#!/bin/sh
# Muninn pre-commit: fast format + vet on staged Go changes.
#
# Bypass:  SKIP_PRE_COMMIT=1 git commit ...
# Install:  make hooks
set -eu

HOOK_DIR=$(CDPATH= cd -- "$(dirname "$0")" && pwd)
# shellcheck source=lib/common.sh
. "${HOOK_DIR}/lib/common.sh"

if hook_skip SKIP_PRE_COMMIT; then
	exit 0
fi

hook_setup || exit 1

staged_list=$(hook_mktemp muninn-pre-commit-staged)
vet_list=$(hook_mktemp muninn-pre-commit-vet)
trap 'rm -f "$staged_list" "$vet_list" "${vet_list}.uniq"' EXIT INT HUP TERM

staged_go_files >"$staged_list"

if [ ! -s "$staged_list" ]; then
	exit 0
fi

echo "pre-commit: checking staged Go files..."

# Batch gofmt check (one process) then fix and re-stage.
unformatted=
# shellcheck disable=SC2046
unformatted=$(gofmt -l $(tr '\n' ' ' <"$staged_list") 2>/dev/null || true)
if [ -n "$unformatted" ]; then
	echo "pre-commit: formatting:"
	printf '%s\n' "$unformatted" | sed 's/^/  /'
	# shellcheck disable=SC2086
	gofmt -w $unformatted
	# shellcheck disable=SC2086
	git add -- $unformatted
fi

# Vet only packages touched by existing staged files.
while IFS= read -r file; do
	[ -n "$file" ] || continue
	[ -f "$file" ] || continue
	case "$file" in
	integration/*)
		printf '%s\n' '-tags integration ./integration/...' >>"$vet_list"
		;;
	*)
		dir=$(dirname "$file")
		if [ "$dir" = "." ]; then
			printf '%s\n' '.' >>"$vet_list"
		else
			printf '%s\n' "./${dir}" >>"$vet_list"
		fi
		;;
	esac
done <"$staged_list"

sort -u "$vet_list" | awk 'NF' >"${vet_list}.uniq"
mv "${vet_list}.uniq" "$vet_list"

if [ ! -s "$vet_list" ]; then
	echo "pre-commit: ok"
	exit 0
fi

echo "pre-commit: go vet..."
while IFS= read -r args; do
	[ -n "$args" ] || continue
	# shellcheck disable=SC2086
	go vet $args
done <"$vet_list"

echo "pre-commit: ok"
