#!/bin/sh
# Muninn pre-commit: format and vet staged Go changes (fast subset of CI).
#
# Bypass:  SKIP_PRE_COMMIT=1 git commit ...
# Install:  make hooks
set -eu

if [ "${SKIP_PRE_COMMIT:-}" = "1" ]; then
	exit 0
fi

root=$(git rev-parse --show-toplevel) || exit 1
git_dir=$(git rev-parse --git-dir) || exit 1

# Merge commits are validated by CI; keep commits fast.
if [ -f "${git_dir}/MERGE_HEAD" ]; then
	exit 0
fi

cd "$root"
export GOTOOLCHAIN="${GOTOOLCHAIN:-local}"

if ! command -v go >/dev/null 2>&1; then
	echo "pre-commit: go not found on PATH" >&2
	exit 1
fi

staged_list=$(mktemp)
vet_list=$(mktemp)
trap 'rm -f "$staged_list" "$vet_list"' EXIT INT HUP TERM

git diff --cached --name-only --diff-filter=ACMRTUXB -- '*.go' >"$staged_list"

if [ ! -s "$staged_list" ]; then
	exit 0
fi

echo "pre-commit: checking staged Go files..."

# Format only staged files, then re-stage fixes.
needs_fmt=0
while IFS= read -r file; do
	[ -n "$file" ] || continue
	[ -f "$file" ] || continue
	if [ -n "$(gofmt -l "$file")" ]; then
		needs_fmt=1
		printf '  %s\n' "$file"
		gofmt -w "$file"
		git add -- "$file"
	fi
done <"$staged_list"

if [ "$needs_fmt" -eq 1 ]; then
	echo "pre-commit: gofmt applied to staged files (re-staged automatically)"
fi

# Vet only packages touched by staged changes.
while IFS= read -r file; do
	[ -n "$file" ] || continue
	case "$file" in
	integration/*)
		printf '%s\n' '-tags integration ./integration/...' >>"$vet_list"
		;;
	*)
		dir=$(dirname "$file")
		if [ "$dir" = "." ]; then
			printf '%s\n' '.' >>"$vet_list"
		else
			printf '%s\n' "./${dir}" >>"$vet_list"
		fi
		;;
	esac
done <"$staged_list"

sort -u "$vet_list" | awk 'NF' >"${vet_list}.uniq"
mv "${vet_list}.uniq" "$vet_list"

if [ ! -s "$vet_list" ]; then
	echo "pre-commit: ok"
	exit 0
fi

echo "pre-commit: go vet..."
while IFS= read -r args; do
	[ -n "$args" ] || continue
	# shellcheck disable=SC2086
	go vet $args
done <"$vet_list"

echo "pre-commit: ok"
