{
  "runs": [
    {
      "tool": {
        "driver": {
          "rules": [
            {
              "id": "pull-request-target",
              "name": "PullRequestTarget",
              "helpUri": "https://woodruffw.github.io/zizmor/audits/pull-request-target",
              "defaultConfiguration": {
                "level": "error"
              }
            },
            {
              "id": "unpinned-uses",
              "name": "UnpinnedUses",
              "helpUri": "https://woodruffw.github.io/zizmor/audits/unpinned-uses",
              "defaultConfiguration": {
                "level": "warning"
              }
            },
            {
              "id": "excessive-permissions",
              "name": "ExcessivePermissions",
              "helpUri": "https://woodruffw.github.io/zizmor/audits/excessive-permissions",
              "defaultConfiguration": {
                "level": "note"
              }
            }
          ]
        }
      },
      "results": [
        {
          "ruleId": "pull-request-target",
          "level": "error",
          "message": {
            "text": "pull_request_target used with an explicit checkout of the triggering PR"
          },
          "locations": [
            {
              "physicalLocation": {
                "artifactLocation": {
                  "uri": ".github/workflows/deploy.yml"
                },
                "region": {
                  "startLine": 5,
                  "startColumn": 1
                }
              }
            }
          ],
          "fingerprints": {
            "primary": "a1b2c3d4e5f60001"
          }
        },
        {
          "ruleId": "unpinned-uses",
          "level": "warning",
          "message": {
            "text": "action uses a mutable ref (branch/tag) instead of a pinned SHA"
          },
          "locations": [
            {
              "physicalLocation": {
                "artifactLocation": {
                  "uri": ".github/workflows/ci.yml"
                },
                "region": {
                  "startLine": 23,
                  "startColumn": 9
                }
              }
            }
          ]
        },
        {
          "ruleId": "excessive-permissions",
          "level": "note",
          "message": {
            "text": "workflow has write access to contents but only reads are needed"
          },
          "locations": [
            {
              "physicalLocation": {
                "artifactLocation": {
                  "uri": ".github/workflows/ci.yml"
                },
                "region": {
                  "startLine": 9,
                  "startColumn": 1
                }
              }
            }
          ],
          "fingerprints": {
            "primary": "f0e1d2c3b4a50003"
          }
        }
      ]
    }
  ]
}
